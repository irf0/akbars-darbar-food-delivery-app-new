{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
     "strict": true,
     "ignoreDeprecations": "6.0",
    "baseUrl": "./",
    "paths": {
      "@components/*": ["src/components/*"],
      "@ui/*":         ["src/components/ui/*"],
      "@hooks/*":      ["src/hooks/*"],
      "@store/*":      ["src/store/*"],
      "@services/*":   ["src/services/*"],
      "@theme/*":      ["src/theme/*"],
      "@utils/*":      ["src/utils/*"],
      "@types/*":      ["src/types/*"],
      "@config/*":     ["src/config/*"],
      "@screens/*":    ["src/screens/*"],
      "@navigation/*": ["src/navigation/*"]
    }
  }
}